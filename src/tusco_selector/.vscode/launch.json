    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Python Debugger: TUSCO CLI (hsa)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/tusco_selector/cli.py",
            "args": [
                "hsa", 
                "--output-dir", "hsa_output_gtfs",
                // Step 3: Splice junction and TSS filtering thresholds
                "--tss-scope", "single",
                "--tss-region-check", "300",
                "--novel-threshold", "0.01",
                "--min-novel-length", "80",
                // Step 5: Expression filtering thresholds - Hybrid (Human): Bgee for universal + GTEx for tissue-specific
                "--expression-source", "auto",
                // Bgee parameters for universal genes
                "--min-genes-per-tissue", "25000",
                "--bgee-quality", "gold quality", "silver quality", "bronze quality",
                "--bgee-prevalence-threshold", "0.95",
                // GTEx parameters for tissue-specific genes - RELAXED FOR MORE GENES
                "--gtex-prevalence-expression-cutoff", "0.1",
                "--gtex-median-expression-cutoff", "1.0",
                "--gtex-prevalence-threshold", "0.95",
                // Step 5: Expression filtering thresholds - Alphagenome Universal (class-specific, RPKM)
                "--single-exon-median-rpkm-threshold", "1.0",
                "--multi-exon-median-rpkm-threshold", "1.0",
                "--single-exon-expression-threshold", "0.05",
                "--multi-exon-expression-threshold", "0.05",
                "--single-exon-prevalence-threshold", "0.95",
                "--multi-exon-prevalence-threshold", "0.95",
                "--splice-ratio-threshold", "0.001",
                "--splice-purity-threshold", "0.95",
                // Step 5: Expression filtering thresholds - Alphagenome Tissue-specific (stricter)
                "--tissue-expression-threshold", "2",
                "--tissue-splice-ratio-threshold", "0.001"
            ],
            "console": "integratedTerminal",
            "justMyCode": true, // Optional: Set to false if you need to step into library code
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            }
        },
        {
            "name": "Python Debugger: TUSCO CLI (mmu)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/src/tusco_selector/cli.py",
            "args": [
                "mmu", 
                "--output-dir", "mmu_output_gtfs",
                // Step 3: Splice junction and TSS filtering thresholds
                "--tss-scope", "single",
                "--novel-threshold", "0.05",
                "--min-novel-length", "80",
                // Step 5: Expression filtering thresholds - Bgee
                "--expression-source", "bgee",
                "--min-genes-per-tissue", "25000",
                "--bgee-quality", "gold quality", "silver quality",
                "--bgee-prevalence-threshold", "0.90",
                // Step 6: Expression filtering thresholds - Alphagenome Universal (class-specific, RPKM)
                "--single-exon-median-rpkm-threshold", "0.5",
                "--multi-exon-median-rpkm-threshold", "0.25",
                "--single-exon-expression-threshold", "0.01",
                "--multi-exon-expression-threshold", "0.005",
                "--single-exon-prevalence-threshold", "0.90",
                "--multi-exon-prevalence-threshold", "0.90",
                "--splice-ratio-threshold", "0.01",
                "--splice-purity-threshold", "0.90",
                // Step 7: Expression filtering thresholds - Alphagenome Tissue-specific (stricter)
                "--tissue-expression-threshold", "1.5",
                "--tissue-splice-ratio-threshold", "0.001",
                // Optional: ENCODE augmentation for tissue-specific sets
                "--encode-tissues", "kidney",
                "--encode-prevalence-expression-cutoff", "0.1",
                "--encode-median-expression-cutoff", "1",
                "--encode-prevalence-threshold", "0.95"
            ],
            "console": "integratedTerminal",
            "justMyCode": true,
            "cwd": "${workspaceFolder}",
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src:${env:PYTHONPATH}"
            }
