                "--output_full", "/Users/tianyuan/Desktop/GitHub/TUSCO/tusco_dataset/tusco_human_full.gtf",
                "--log", "/Users/tianyuan/Desktop/GitHub/TUSCO/tusco_dataset/tusco_human_sim.log",
