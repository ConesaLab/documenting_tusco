@article{nip_reference-free_2023,
	title = {Reference-free assembly of long-read transcriptome sequencing data with {RNA}-{Bloom2}},
	volume = {14},
	issn = {2041-1723},
	url = {https://www.nature.com/articles/s41467-023-38553-y},
	doi = {10.1038/s41467-023-38553-y},
	abstract = {Abstract
            
              Long-read sequencing technologies have improved significantly since their emergence. Their read lengths, potentially spanning entire transcripts, is advantageous for reconstructing transcriptomes. Existing long-read transcriptome assembly methods are primarily reference-based and to date, there is little focus on reference-free transcriptome assembly. We introduce “RNA-Bloom2 [
              https://github.com/bcgsc/RNA-Bloom
              ]”, a reference-free assembly method for long-read transcriptome sequencing data. Using simulated datasets and spike-in control data, we show that the transcriptome assembly quality of RNA-Bloom2 is competitive to those of reference-based methods. Furthermore, we find that RNA-Bloom2 requires 27.0 to 80.6\% of the peak memory and 3.6 to 10.8\% of the total wall-clock runtime of a competing reference-free method. Finally, we showcase RNA-Bloom2 in assembling a transcriptome sample of
              Picea sitchensis
              (Sitka spruce). Since our method does not rely on a reference, it further sets the groundwork for large-scale comparative transcriptomics where high-quality draft genome assemblies are not readily available.},
	language = {en},
	number = {1},
	urldate = {2026-01-12},
	journal = {Nat Commun},
	author = {Nip, Ka Ming and Hafezqorani, Saber and Gagalova, Kristina K. and Chiu, Readman and Yang, Chen and Warren, René L. and Birol, Inanc},
	month = may,
	year = {2023},
	keywords = {Software, Genome informatics, Data processing},
	pages = {2940},
	annote = {publisher: Nature Publishing Group},
	file = {PDF:/Users/tianyuan/Zotero/storage/9I5UW65L/Nip et al. - 2023 - Reference-free assembly of long-read transcriptome sequencing data with RNA-Bloom2.pdf:application/pdf},
}

