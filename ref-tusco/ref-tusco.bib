	file = {Full Text PDF:/Users/tianyuan/Zotero/storage/TZQP49HV/Paniagua et al. - 2024 - Evaluation of strategies for evidence-driven genome annotation using long-read RNA-seq.pdf:application/pdf;PDF:/Users/tianyuan/Zotero/storage/YVBDKAGD/Paniagua et al. - 2025 - Evaluation of strategies for evidence-driven genome annotation using long-read RNA-seq.pdf:application/pdf},
